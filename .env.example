# ── Server ───────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ── Admin login (super-admin) ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=Administrator
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_HOURS=12

# ── Databases ────────────────────────────────────────────────────────
# Structured data (people, attendance, stations, holidays) — Neon Postgres.
DATABASE_URL=postgresql+psycopg2://user:password@ep-xyz-pooler.region.neon.tech/dbname
DATABASE_SSLMODE=require

# Fingerprint templates — local SQLite by default. Override to use Postgres.
# PYTHON_DATABASE_URL=postgresql+psycopg2://user:password@host/db

# ── Attendance ───────────────────────────────────────────────────────
CHECKIN_COOLDOWN_MINUTES=5
