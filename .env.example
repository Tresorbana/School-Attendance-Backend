# ── Server ───────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
# Set to your domain in production — NEVER use * in production
CORS_ORIGIN=https://yourdomain.com
NODE_ENV=production

# Set to true when the backend is behind a reverse proxy (Nginx).
# This makes the rate limiter read X-Forwarded-For for real client IPs.
# Leave false if the backend is directly exposed (not recommended in prod).
TRUST_PROXY=true

# ── School identity ───────────────────────────────────────────────────
SCHOOL_NAME=Your School Name

# ── Admin login ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Use a strong password (16+ chars). Run: python app.py --hash-password "yourpassword"
# to pre-hash it, or let the app hash it on first login.
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_FULL_NAME=Administrator
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-random-hex-chars-generated-by-secrets-token-hex-32
JWT_EXPIRES_HOURS=8

# ── Databases ────────────────────────────────────────────────────────
# Local PostgreSQL (VPS) or NeonDB (cloud):
DATABASE_URL=postgresql+psycopg2://sams:strong_db_password@localhost:5432/sams
DATABASE_SSLMODE=require

# Fingerprint templates — local SQLite on the same VPS disk
# TEMPLATES_DB_URL=sqlite:////opt/sams/fingerprint_templates.db

# ── Attendance rules ──────────────────────────────────────────────────
CHECKIN_COOLDOWN_MINUTES=5
LATE_GRACE_MINUTES=5
EARLY_DEPARTURE_GRACE_MINUTES=5

# ── Relay (local Windows client) ─────────────────────────────────────
# URL of the VPS backend — relay forwards fingerprint scans here
VPS_URL=http://your-vps-ip-or-domain
RELAY_PORT=8001
