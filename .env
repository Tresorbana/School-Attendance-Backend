PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*
NODE_ENV=development
TRUST_PROXY=false

SCHOOL_NAME=My School

ADMIN_USERNAME=sams_admin
ADMIN_PASSWORD=admin1234
ADMIN_FULL_NAME=SAMS Administrator
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_EXPIRES_HOURS=12

# Structured data — local SQLite. No network dependency, instant startup.
# To return to Neon, swap to:
#   postgresql+psycopg2://user:pass@host/db?sslmode=require
DATABASE_URL=sqlite:///D:/NemaTechnologies/Attendance/backend/sams.db
DATABASE_SSLMODE=disable

# Fingerprint templates already on local SQLite by default.

CHECKIN_COOLDOWN_MINUTES=5
